=====================================================#}

{% extends 'pages/base.jinja' %}


{% block content %}

    <section id="messages-list">

        {% for message in messages %}

            <div class="message-item">
                <h3>{{ message.title }}</h3>
                <p>{{ message.text }}</p>
            </div>

        {% else %}

            <p>There's nothing here...</p>

        {% endfor %}

    </section>

{% endblock %}