{#=====================================================
  Browse page
=====================================================#}

{% extends 'pages/base.jinja' %}


{% block content %}

    <section id="messages-list">

        {% for message in messages %}

            <div class="message-item">
                <h3>{{ message.title }}</h3>
                <p>{{ message.text }}</p>
                {% if session.logged_in and session.user.id == message.user_id %}
                <a href="/message/edit/{{ message.id }}">Edit</a>
                <a href="/message/delete/{{ message.id }}">Delete</a>
                {% endif %}
            </div>

        {% else %}

            <p>There's nothing here...</p>

        {% endfor %}

    </section>

{% endblock %}