{#=====================================================
  Login page
=====================================================#}

{% extends 'pages/base.jinja' %}


{% block content %}

    <h2>Log In</h2>

    <form method="post" action="/Login">
      <label>
        username
        <input type="text" name="username" required>
      </label>
      <label>
        Password
        <input type="password" name="password" required>
      </label>
      <button>Login</button>
    </form>

{% endblock %}

