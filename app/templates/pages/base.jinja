{#=====================================================
  Base template
  - Used as the basis of all pages
=====================================================#}

<!DOCTYPE html>

<html lang="en" data-theme="light">

<head>
	<meta charset="utf-8">
	<meta name="viewport" content="width=device-width, initial-scale=1">

	<title> FamiComs {% block title %}{% endblock %}</title>

    <link rel="icon" href="/static/images/dpad.png">

    <script src="/static/js/utils.js"></script>

    <link rel="stylesheet" href="/static/css/reset.css">
    <link rel="stylesheet" href="/static/css/messages.css">
    <link rel="stylesheet" href="/static/css/styles.css">
</head>

<body>

    <header>
        <a href="/">
            <img src="/static/images/dpad.png" alt="D-Pad Icon" class="logo">
        </a>

        <h1>FamiComs</h1>

        <nav>
            {% if session.logged_in %}
                Welcome, {{ session.user.firstname }}!
                <a href="/">Home</a>
                <a href="/message/new">Post</a>
                <a href="/message/view">Browse</a>
                <a href="/help">Admin</a>
                <a href="/logout">Logout</a>
            {% else %}
                <a href="/">Home</a>
                <a href="/message/view">Browse</a>
                <a href="/user/login">Login</a>
                <a href="/user/new">Sign-Up</a>
            {% endif %}
        </nav>
    </header>

    {# Show flash messages from any previous events #}
    {% include "partials/messages.jinja" %}

    <main>

        {% block content %}
        {% endblock %}

    </main>

</body>

</html>

